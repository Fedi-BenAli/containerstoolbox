#!/bin/bash

# Get one of the ovnkube-master pods to run ovn-nbctl commands
OVN_MASTER=$(oc get pods -n openshift-ovn-kubernetes -l app=ovnkube-master -o name | head -n 1)

if [ -z "$OVN_MASTER" ]; then
    echo "Error: Could not find ovnkube-master pod."
    exit 1
fi

echo "Using OVN Master Pod: $OVN_MASTER"
echo "--------------------------------------------------------"

# Get all namespaces excluding OpenShift/Kube system namespaces
NAMESPACES=$(oc get namespaces -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | grep -vE "openshift|kube-|default|node-tracking")

for NS in $NAMESPACES; do
    # Check if there is at least one running pod in the namespace
    RUNNING_POD=$(oc get pods -n "$NS" --field-selector=status.phase=Running -o name | head -n 1)
    
    if [ -z "$RUNNING_POD" ]; then
        continue
    fi

    # Find EgressIP objects that target this namespace
    # This checks if the namespace name is explicitly listed in the EgressIP spec
    EGRESS_DATA=$(oc get egressip -o json | jq -c --arg ns "$NS" '.items[] | select(.spec.namespaces[] == $ns)')

    if [ -z "$EGRESS_DATA" ]; then
        # If not found by name, it might be targeted by labels (common in larger setups)
        # For simplicity, this script focuses on direct namespace matching.
        continue
    fi

    EIP_NAME=$(echo "$EGRESS_DATA" | jq -r '.metadata.name')
    EXPECTED_IPS=$(echo "$EGRESS_DATA" | jq -r '.spec.egressIPs[]')
    
    echo "Namespace: $NS (Pod: ${RUNNING_POD#pod/})"
    echo "  EgressIP Object: $EIP_NAME"

    for IP in $EXPECTED_IPS; do
        # Query OVN Northbound DB for the NAT rule
        # We look for snat rules where the external_ip matches our EgressIP
        NAT_CHECK=$(oc exec -n openshift-ovn-kubernetes "$OVN_MASTER" -c ovnkube-master -- ovn-nbctl find nat external_ip="$IP" | grep "external_ip")

        if [ -n "$NAT_CHECK" ]; then
            echo "  [OK] NAT Rule exists for Physical IP: $IP"
        else
            echo "  [FAIL] Missing NAT Rule for Physical IP: $IP"
        fi
    done
    echo "--------------------------------------------------------"
done
