#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to log messages
log() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[$(date '+%Y-%m-%d %H:%M:%S')] WARNING:${NC} $1"
}

error() {
    echo -e "${RED}[$(date '+%Y-%m-%d %H:%M:%S')] ERROR:${NC} $1"
}

# Function to check if namespace should be skipped
should_skip_namespace() {
    local namespace=$1
    local skip_patterns=(
        "openshift-"
        "kube-"
        "istio-"
        "knative-"
        "tekton-"
        "default"
        "kubernetes-dashboard"
    )
    
    for pattern in "${skip_patterns[@]}"; do
        if [[ $namespace == $pattern* ]]; then
            return 0
        fi
    done
    return 1
}

# Function to get EgressIP for a namespace
get_namespace_egressip() {
    local namespace=$1
    oc get netnamespace "$namespace" -o jsonpath='{.egressIPs}' 2>/dev/null
}

# Function to get running pod from namespace
get_running_pod() {
    local namespace=$1
    oc get pods -n "$namespace" --field-selector=status.phase=Running -o jsonpath='{.items[0].metadata.name}' 2>/dev/null
}

# Function to get pod's node
get_pod_node() {
    local namespace=$1
    local pod=$2
    oc get pod "$pod" -n "$namespace" -o jsonpath='{.spec.nodeName}' 2>/dev/null
}

# Function to get pod's IP
get_pod_ip() {
    local namespace=$1
    local pod=$2
    oc get pod "$pod" -n "$namespace" -o jsonpath='{.status.podIP}' 2>/dev/null
}

