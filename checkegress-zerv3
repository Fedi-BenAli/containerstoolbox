#!/bin/bash
# =============================================================================
# check_egressip_nat.sh
# Verifies that each application namespace has 2 OVN NAT rules configured,
# one for each EgressIP physical IP.
# =============================================================================

set -euo pipefail

# --------------------------------------------------------------------------
# Color / formatting helpers
# --------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

pass()  { echo -e "  ${GREEN}[PASS]${RESET} $*"; }
fail()  { echo -e "  ${RED}[FAIL]${RESET} $*"; }
warn()  { echo -e "  ${YELLOW}[WARN]${RESET} $*"; }
info()  { echo -e "  ${CYAN}[INFO]${RESET} $*"; }
header(){ echo -e "\n${BOLD}=== $* ===${RESET}"; }

# --------------------------------------------------------------------------
# Namespaces to always skip (OpenShift / Kubernetes system namespaces)
# --------------------------------------------------------------------------
SYSTEM_NS_PREFIXES=(
  "openshift"
  "kube"
  "default"
)

# Add any extra namespaces you want to exclude here
EXTRA_SKIP_NS=(
  # "my-infra-ns"
)

is_system_ns() {
  local ns="$1"
  for prefix in "${SYSTEM_NS_PREFIXES[@]}"; do
    [[ "$ns" == "$prefix" || "$ns" == ${prefix}-* ]] && return 0
  done
  for skip in "${EXTRA_SKIP_NS[@]}"; do
    [[ "$ns" == "$skip" ]] && return 0
  done
  return 1
}

# --------------------------------------------------------------------------
# Prerequisites check
# --------------------------------------------------------------------------
header "Prerequisites"
for cmd in oc ovn-nbctl jq; do
  if command -v "$cmd" &>/dev/null; then
    pass "$cmd found"
  else
    fail "$cmd not found - install it or run on a node/bastion with OVN DB access"
    [[ "$cmd" != "jq" ]] && exit 1
  fi
done

# --------------------------------------------------------------------------
# Step 1 - Collect EgressIP addresses from the cluster
# --------------------------------------------------------------------------
header "Step 1 - Collecting EgressIP addresses"

mapfile -t EGRESS_IPS < <(
  oc get egressip -o json 2>/dev/null \
  | jq -r '.items[].status.items[].egressIP' 2>/dev/null \
  | sort -u
)

if [[ ${#EGRESS_IPS[@]} -eq 0 ]]; then
  warn "No EgressIP addresses found via 'oc get egressip'. NAT count checks will still run."
else
  info "Found ${#EGRESS_IPS[@]} EgressIP address(es): ${EGRESS_IPS[*]}"
fi

EXPECTED_NAT_COUNT=2   # adjust if you have more/fewer EgressIPs per namespace

# --------------------------------------------------------------------------
# Step 2 - Get all namespaces, filter out system ones
# --------------------------------------------------------------------------
header "Step 2 - Collecting application namespaces"

mapfile -t ALL_NS < <(oc get namespaces -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n')

APP_NS=()
SKIPPED_NS=()
for ns in "${ALL_NS[@]}"; do
  if is_system_ns "$ns"; then
    SKIPPED_NS+=("$ns")
  else
    APP_NS+=("$ns")
  fi
done

info "Total namespaces : ${#ALL_NS[@]}"
info "System (skipped) : ${#SKIPPED_NS[@]}"
info "Application      : ${#APP_NS[@]}"

if [[ ${#APP_NS[@]} -eq 0 ]]; then
  warn "No application namespaces found. Exiting."
  exit 0
fi

# --------------------------------------------------------------------------
# Step 3 - For each app namespace: pick one running pod, check NAT rules
# --------------------------------------------------------------------------
header "Step 3 - Checking OVN NAT rules per namespace"

PASS_COUNT=0
FAIL_COUNT=0
SKIP_COUNT=0
RESULTS=()

for ns in "${APP_NS[@]}"; do
  echo -e "\n${BOLD}Namespace: $ns${RESET}"

  # Pick one running pod
  POD=$(oc get pods -n "$ns" \
        --field-selector=status.phase=Running \
        -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)

  if [[ -z "$POD" ]]; then
    warn "No running pods - skipping"
    RESULTS+=("SKIP  | $ns | no running pods")
    (( SKIP_COUNT++ ))
    continue
  fi
  info "Using pod: $POD"

  # Get pod IP
  POD_IP=$(oc get pod "$POD" -n "$ns" \
           -o jsonpath='{.status.podIP}' 2>/dev/null || true)

  if [[ -z "$POD_IP" ]]; then
    warn "Could not determine pod IP - skipping"
    RESULTS+=("SKIP  | $ns | pod $POD has no IP")
    (( SKIP_COUNT++ ))
    continue
  fi
  info "Pod IP: $POD_IP"

  # Query OVN NB database for SNAT rules matching this pod's logical IP
  NAT_OUTPUT=$(ovn-nbctl --format=list \
               find NAT type=snat "logical_ip=\"${POD_IP}\"" 2>/dev/null || true)

  # Fallback without quote escaping (some versions differ)
  if [[ -z "$NAT_OUTPUT" ]]; then
    NAT_OUTPUT=$(ovn-nbctl find NAT type=snat logical_ip="${POD_IP}" 2>/dev/null || true)
  fi

  # Each NAT entry starts with "_uuid"
  NAT_COUNT=$(echo "$NAT_OUTPUT" | grep -c '^_uuid' || true)
  info "NAT rules found: $NAT_COUNT (expected: $EXPECTED_NAT_COUNT)"

  # Verify each known EgressIP appears as external_ip in a NAT rule
  MISSING_IPS=()
  if [[ ${#EGRESS_IPS[@]} -gt 0 && -n "$NAT_OUTPUT" ]]; then
    for eip in "${EGRESS_IPS[@]}"; do
      if ! echo "$NAT_OUTPUT" | grep -q "external_ip.*${eip}"; then
        MISSING_IPS+=("$eip")
      fi
    done
  fi

  # Evaluate
  if [[ "$NAT_COUNT" -ge "$EXPECTED_NAT_COUNT" && ${#MISSING_IPS[@]} -eq 0 ]]; then
    pass "Pod $POD: $NAT_COUNT NAT rule(s) - all EgressIPs present"
    RESULTS+=("PASS  | $ns | pod=$POD ip=$POD_IP nat_rules=$NAT_COUNT")
    (( PASS_COUNT++ ))
  elif [[ "$NAT_COUNT" -ge "$EXPECTED_NAT_COUNT" && ${#MISSING_IPS[@]} -gt 0 ]]; then
    fail "Pod $POD: $NAT_COUNT NAT rule(s) but missing EgressIP(s): ${MISSING_IPS[*]}"
    RESULTS+=("FAIL  | $ns | pod=$POD ip=$POD_IP nat_rules=$NAT_COUNT missing_eips=${MISSING_IPS[*]}")
    (( FAIL_COUNT++ ))
  else
    fail "Pod $POD: only $NAT_COUNT / $EXPECTED_NAT_COUNT expected NAT rule(s)"
    RESULTS+=("FAIL  | $ns | pod=$POD ip=$POD_IP nat_rules=$NAT_COUNT expected=$EXPECTED_NAT_COUNT")
    (( FAIL_COUNT++ ))
  fi

  # Uncomment to see raw OVN output per pod:
  # echo "$NAT_OUTPUT"
done

# --------------------------------------------------------------------------
# Step 4 - Summary
# --------------------------------------------------------------------------
header "Summary"
printf "%-6s | %-40s | %s\n" "STATUS" "NAMESPACE" "DETAILS"
printf '%0.s-' {1..90}; echo
for line in "${RESULTS[@]}"; do
  case "$line" in
    PASS*) echo -e "${GREEN}${line}${RESET}" ;;
    FAIL*) echo -e "${RED}${line}${RESET}" ;;
    *)     echo -e "${YELLOW}${line}${RESET}" ;;
  esac
done

echo ""
echo -e "${BOLD}Totals:${RESET}  ${GREEN}PASS=$PASS_COUNT${RESET}  ${RED}FAIL=$FAIL_COUNT${RESET}  ${YELLOW}SKIP=$SKIP_COUNT${RESET}"

[[ $FAIL_COUNT -eq 0 ]] && exit 0 || exit 1
