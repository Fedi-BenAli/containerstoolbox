#!/usr/bin/env bash
set -euo pipefail

# Arrays to store results
declare -a UNUSED_EGRESS_IPS
declare -a ACTIVE_EGRESS_IPS

echo "Starting EgressIP Audit..."
echo "----------------------------------------------------"

# 1. Get all EgressIP resources in JSON format
# We need the name of the EgressIP and the list of namespaces it applies to.
# Adjust the API group if necessary (usually k8s.ovn.org/v1)
egress_resources=$(kubectl get egressips.k8s.ovn.org -o json)

# 2. Iterate through each EgressIP resource
# We use jq to output a stream of "EgressIPName Namespace1 Namespace2..."
while read -r line; do
    # Read the line into an array
    # Index 0 is the EgressIP Name
    # Index 1..N are the Namespaces
    read -r -a parts <<< "$line"
    
    egress_ip_name="${parts[0]}"
    
    # If there are no namespaces assigned (length is 1), it's definitely unused
    if [[ ${#parts[@]} -le 1 ]]; then
        echo "[UNUSED] $egress_ip_name (No namespaces assigned)"
        UNUSED_EGRESS_IPS+=("$egress_ip_name")
        continue
    fi

    # Extract namespaces (slice array from index 1 to end)
    namespaces=("${parts[@]:1}")
    
    echo "Checking EgressIP: $egress_ip_name"
    echo "  -> Assigned Namespaces: ${namespaces[*]}"

    has_active_pods=0

    # 3. Check each assigned namespace for running pods
    for ns in "${namespaces[@]}"; do
        # Count pods in this namespace. 
        # We assume 'Running' or 'ContainerCreating' indicates usage. 
        # If you want ANY pod status (even Failed/Completed), remove the field-selector.
        pod_count=$(kubectl get pods -n "$ns" --field-selector=status.phase=Running --no-headers 2>/dev/null | wc -l || echo 0)
        
        # Also check for Pending/ContainerCreating to be safe, or just check total count:
        # pod_count=$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | wc -l)

        if [[ "$pod_count" -gt 0 ]]; then
            echo "    -> Found $pod_count running pods in namespace '$ns'. (IN USE)"
            has_active_pods=1
            # Optimization: If we find one pod, the EgressIP is in use. We can stop checking other namespaces.
            break 
        else
            echo "    -> Namespace '$ns' has 0 running pods."
        fi
    done

    # 4. Categorize result
    if [[ $has_active_pods -eq 0 ]]; then
        echo "  -> RESULT: UNUSED (No running pods in any assigned namespace)"
        UNUSED_EGRESS_IPS+=("$egress_ip_name")
    else
        ACTIVE_EGRESS_IPS+=("$egress_ip_name")
    fi
    echo "----------------------------------------------------"

done < <(echo "$egress_resources" | jq -r '.items[] | "\(.metadata.name) " + (.spec.namespaceSelector.matchLabels | keys[]? // empty)')

# Note on jq query above:
# It assumes the standard OVN-Kubernetes EgressIP structure where namespaces are selected via matchLabels.
# If your EgressIP uses specific namespace names directly, the jq query needs slight adjustment.
# The query above extracts: "Name LabelKey" (It's actually harder to resolve selectors to names purely in jq without kubectl queries).

# --- ALTERNATIVE PARSING STRATEGY (More Robust) ---
# Since namespaceSelector matches LABELS, not names directly, we must resolve the selector.

echo "Re-evaluating logic with precise Namespace Selector resolution..."
# Reset arrays for the robust pass
UNUSED_EGRESS_IPS=()

# Get list of all EgressIP names
egress_names=$(kubectl get egressips.k8s.ovn.org -o jsonpath='{.items[*].metadata.name}')

for egress_name in $egress_names; do
    echo "Inspecting: $egress_name"
    
    # Get the IPs (just for display/verification)
    ips=$(kubectl get egressips.k8s.ovn.org "$egress_name" -o jsonpath='{.spec.egressIPs[*]}')
    
    # Get the Namespace Selector Labels
    # Output format: key=value,key=value
    selector_raw=$(kubectl get egressips.k8s.ovn.org "$egress_name" -o json | jq -r '.spec.namespaceSelector.matchLabels | to_entries | map("\(.key)=\(.value)") | join(",")')

    if [[ -z "$selector_raw" || "$selector_raw" == "null" ]]; then
        echo "  -> No Namespace selector found. Marked UNUSED."
        UNUSED_EGRESS_IPS+=("$egress_name ($ips)")
        continue
    fi

    echo "  -> IPs: $ips"
    echo "  -> Selector: $selector_raw"

    # Find namespaces that match this label selector
    target_namespaces=$(kubectl get namespaces -l "$selector_raw" -o jsonpath='{.items[*].metadata.name}')

    if [[ -z "$target_namespaces" ]]; then
        echo "  -> Selector matches NO namespaces. Marked UNUSED."
        UNUSED_EGRESS_IPS+=("$egress_name ($ips)")
        continue
    fi

    pods_found=0
    for ns in $target_namespaces; do
        # Check for pods
        count=$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | wc -l)
        if [[ $count -gt 0 ]]; then
            echo "  -> Used by namespace '$ns' ($count pods)"
            pods_found=1
            break # Found usage, move to next EgressIP
        fi
    done

    if [[ $pods_found -eq 0 ]]; then
        echo "  -> No pods found in matching namespaces ($target_namespaces)."
        UNUSED_EGRESS_IPS+=("$egress_name ($ips)")
    fi
    echo "---"
done

# ==========================================
# FINAL OUTPUT
# ==========================================

echo ""
echo "=========================================="
echo "SUMMARY: UNUSED EGRESS IP RESOURCES"
echo "=========================================="

if [[ ${#UNUSED_EGRESS_IPS[@]} -eq 0 ]]; then
    echo "All EgressIPs are currently in use."
else
    for item in "${UNUSED_EGRESS_IPS[@]}"; do
        echo "- $item"
    done
fi
echo "=========================================="
