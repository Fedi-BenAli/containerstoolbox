#!/usr/bin/env bash
set -euo pipefail

# Check requirements (errors go to stderr)
command -v kubectl >/dev/null 2>&1 || { echo >&2 "Error: kubectl is required but not found. Aborting."; exit 1; }
command -v jq >/dev/null 2>&1 || { echo >&2 "Error: jq is required but not found. Aborting."; exit 1; }

# Array to store the names of unused EgressIP resources
declare -a UNUSED_EGRESS_IP_RESOURCES

# 1. Get all EgressIP resources
egress_names=$(kubectl get egressips.k8s.ovn.org -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)

# If no EgressIP resources are found, egress_names will be empty.
# In this case, we'll output an empty line (or nothing if you prefer).
if [[ -z "$egress_names" ]]; then
    exit 0 # No EgressIPs found, so no unused IPs. Exit quietly.
fi

for egress_name in $egress_names; do
    egress_data=$(kubectl get egressips.k8s.ovn.org "$egress_name" -o json)
    
    # Extract matchLabels. If null, set empty.
    selector_string=$(echo "$egress_data" | jq -r '
        if .spec.namespaceSelector.matchLabels then 
            .spec.namespaceSelector.matchLabels | to_entries | map("\(.key)=\(.value)") | join(",") 
        else 
            "" 
        end
    ')

    # 2. Resolve Namespaces that match the selector
    target_namespaces=""
    
    if [[ -n "$selector_string" ]]; then # Only query if a selector exists
        target_namespaces=$(kubectl get namespaces -l "$selector_string" -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)
    fi

    # 3. Check for Pods in identified namespaces
    has_active_pods=0
    
    # If no namespaces match the selector (or no selector), it's considered unused for our purpose.
    # Otherwise, check for pods in the matched namespaces.
    if [[ -n "$target_namespaces" ]]; then
        for ns in $target_namespaces; do
            # Check for ANY pod.
            pod_count=$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | wc -l)
            
            if [[ "$pod_count" -gt 0 ]]; then
                has_active_pods=1
                break # Found usage, move to next EgressIP resource
            fi
        done
    fi

    # 4. Result for this EgressIP resource
    if [[ $has_active_pods -eq 0 ]]; then
        UNUSED_EGRESS_IP_RESOURCES+=("$egress_name") # Store only the name
    fi
done

# ==========================================
# FINAL OUTPUT: Only the comma-separated IP list
# ==========================================

declare -a ALL_UNUSED_IPS

if [[ ${#UNUSED_EGRESS_IP_RESOURCES[@]} -gt 0 ]]; then
    for res_name in "${UNUSED_EGRESS_IP_RESOURCES[@]}"; do
        # Fetch IPs again for the specific unused resource
        current_ips=$(kubectl get egressips.k8s.ovn.org "$res_name" -o jsonpath='{.spec.egressIPs[*]}' 2>/dev/null || true)
        for ip in $current_ips; do
            ALL_UNUSED_IPS+=("$ip")
        done
    done
fi

# Join all collected IPs with a comma and print to stdout
# If ALL_UNUSED_IPS is empty, this will print an empty line.
IFS=, eval 'echo "${ALL_UNUSED_IPS[*]}"'



