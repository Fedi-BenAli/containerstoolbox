#!/usr/bin/env bash
set -euo pipefail

# Check requirements
command -v kubectl >/dev/null 2>&1 || { echo >&2 "kubectl is required. Aborting."; exit 1; }
command -v jq >/dev/null 2>&1 || { echo >&2 "jq is required. Aborting."; exit 1; }

# Array to store results
declare -a UNUSED_EGRESS_IPS

echo "=========================================="
echo "Starting EgressIP Usage Audit"
echo "=========================================="

# 1. Get all EgressIP resources
# We iterate through them one by one to safely handle complex selectors
egress_names=$(kubectl get egressips.k8s.ovn.org -o jsonpath='{.items[*].metadata.name}')

for egress_name in $egress_names; do
    echo "Processing EgressIP: $egress_name"
    
    # 2. Extract Data: IPs and the Namespace Selector Map
    # We use jq to turn the map {"env":"prod", "team":"blue"} into a string "env=prod,team=blue"
    # This format is exactly what 'kubectl get namespaces -l' expects.
    
    egress_data=$(kubectl get egressips.k8s.ovn.org "$egress_name" -o json)
    
    ips=$(echo "$egress_data" | jq -r '.spec.egressIPs | join(", ")')
    
    # Extract matchLabels. If null, set empty.
    # Logic: to_entries -> map key=value -> join with comma
    selector_string=$(echo "$egress_data" | jq -r '
        if .spec.namespaceSelector.matchLabels then 
            .spec.namespaceSelector.matchLabels | to_entries | map("\(.key)=\(.value)") | join(",") 
        else 
            "" 
        end
    ')

    # 3. Resolve Namespaces
    target_namespaces=""
    
    if [[ -z "$selector_string" ]]; then
        echo "  -> No namespace selector labels found."
        # Keep empty target_namespaces
    else
        echo "  -> Selector: [$selector_string]"
        # Query K8s for namespaces matching ALL labels in the string
        target_namespaces=$(kubectl get namespaces -l "$selector_string" -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || true)
    fi

    # 4. Check for Pods in identified namespaces
    has_active_pods=0
    
    if [[ -z "$target_namespaces" ]]; then
        echo "  -> No namespaces match this selector."
    else
        # Loop through matched namespaces
        for ns in $target_namespaces; do
            # Check for ANY pod (Running, Pending, etc). 
            # If you only want 'Running', add --field-selector=status.phase=Running
            pod_count=$(kubectl get pods -n "$ns" --no-headers 2>/dev/null | wc -l)
            
            if [[ "$pod_count" -gt 0 ]]; then
                echo "  -> Namespace '$ns' matches and has $pod_count pods. [IN USE]"
                has_active_pods=1
                # Optimization: Found one used namespace, so the EgressIP is used. Stop checking.
                break 
            else
                echo "  -> Namespace '$ns' matches but has 0 pods."
            fi
        done
    fi

    # 5. Result for this EgressIP
    if [[ $has_active_pods -eq 0 ]]; then
        echo "  -> RESULT: UNUSED"
        UNUSED_EGRESS_IPS+=("Name: $egress_name | IPs: [$ips] | Selector: [$selector_string]")
    fi
    echo "------------------------------------------"
done

# ==========================================
# FINAL OUTPUT
# ==========================================

echo ""
echo "=========================================="
echo "SUMMARY: UNUSED EGRESS IP RESOURCES"
echo "=========================================="

if [[ ${#UNUSED_EGRESS_IPS[@]} -eq 0 ]]; then
    echo "All EgressIPs are currently in use."
else
    echo "Found ${#UNUSED_EGRESS_IPS[@]} unused EgressIPs:"
    echo ""
    for item in "${UNUSED_EGRESS_IPS[@]}"; do
        echo "- $item"
    done
fi
echo "=========================================="
