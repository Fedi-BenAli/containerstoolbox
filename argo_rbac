apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: generate-argo-manager-rbac
spec:
  generateExistingOnPolicyUpdate: true
  rules:
    - name: generate-argo-manager-role
      match:
        any:
          - resources:
              kinds:
                - Namespace
              selector:
                matchLabels:
                  argo-client: "true"
      generate:
        apiVersion: rbac.authorization.k8s.io/v1
        kind: Role
        name: argo-manager-role
        namespace: "{{request.object.metadata.name}}"
        synchronize: true
        data:
          rules:
            - apiGroups:
                - "*"
              resources:
                - "*"
              verbs:
                - "*"
    
    - name: generate-argo-manager-rolebinding
      match:
        any:
          - resources:
              kinds:
                - Namespace
              selector:
                matchLabels:
                  argo-client: "true"
      generate:
        apiVersion: rbac.authorization.k8s.io/v1
        kind: RoleBinding
        name: argo-manager-rolebinding
        namespace: "{{request.object.metadata.name}}"
        synchronize: true
        data:
          roleRef:
            apiGroup: rbac.authorization.k8s.io
            kind: Role
            name: argo-manager-role
          subjects:
            - kind: ServiceAccount
              name: argo-manager
              namespace: "{{request.object.metadata.labels.tenant}}-argo-config"
